<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="monthly-report" pageWidth="595" pageHeight="842" columnWidth="535"
              leftMargin="30" rightMargin="30" topMargin="30" bottomMargin="30">

    <parameter name="userId" class="java.lang.String"/>
    <parameter name="month" class="java.lang.Integer"/>
    <parameter name="year" class="java.lang.Integer"/>
    <parameter name="totalIncome" class="java.math.BigDecimal"/>
    <parameter name="averageLast3Months" class="java.math.BigDecimal"/>
    <parameter name="status" class="java.lang.String"/>
    <parameter name="rule" class="java.lang.String"/>
    <parameter name="message" class="java.lang.String"/>

    <field name="label" class="java.lang.String"/>
    <field name="amount" class="java.math.BigDecimal"/>

    <title>
        <band height="80">
            <staticText>
                <reportElement x="0" y="0" width="535" height="30"/>
                <textElement textAlignment="Center">
                    <font size="20" isBold="true"/>
                </textElement>
                <text><![CDATA[Joseph · Yusuf — Rapport mensuel]]></text>
            </staticText>
            <textField>
                <reportElement x="0" y="40" width="535" height="20"/>
                <textElement textAlignment="Center"><font size="12"/></textElement>
                <textFieldExpression><![CDATA["Période : " + $P{month} + "/" + $P{year}]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <pageHeader><band height="20"/></pageHeader>

    <columnHeader>
        <band height="40">
            <textField>
                <reportElement x="0" y="0" width="535" height="18"/>
                <textElement><font size="11" isBold="true"/></textElement>
                <textFieldExpression><![CDATA["Statut du mois : " + $P{status} + " — Règle : " + $P{rule}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="20" width="535" height="18"/>
                <textElement><font size="10"/></textElement>
                <textFieldExpression><![CDATA["Revenu total : " + $P{totalIncome} + " — Moyenne 3 mois : " + $P{averageLast3Months}]]></textFieldExpression>
            </textField>
        </band>
    </columnHeader>

    <detail>
        <band height="22">
            <textField>
                <reportElement x="0" y="0" width="350" height="20"/>
                <textElement><font size="11"/></textElement>
                <textFieldExpression><![CDATA[$F{label}]]></textFieldExpression>
            </textField>
            <textField pattern="#,##0.00">
                <reportElement x="350" y="0" width="185" height="20"/>
                <textElement textAlignment="Right"><font size="11"/></textElement>
                <textFieldExpression><![CDATA[$F{amount}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <summary>
        <band height="60">
            <textField>
                <reportElement x="0" y="20" width="535" height="40"/>
                <textElement><font size="10" isItalic="true"/></textElement>
                <textFieldExpression><![CDATA[$P{message}]]></textFieldExpression>
            </textField>
        </band>
    </summary>
</jasperReport>
