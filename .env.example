# ======================
# APPLICATION (utilisé par docker-compose.yml en dev)
# ======================
DB_USER=joseph
DB_PASSWORD=change_me_in_production
DB_NAME=joseph_db
JWT_SECRET=change_me_64_chars_minimum

# ======================
# PAIEMENTS — bascule globale
# ======================
# false = trials prolongés automatiquement (PAYMENTS_ACTIVE=false par défaut)
# true  = flux de paiement normal + email d'activation envoyé aux users en prolongation
# Valeur d'initialisation seulement : la valeur runtime vit dans
# joseph_auth.system_settings et est basculée depuis le dashboard admin.
PAYMENTS_ACTIVE=false
TRIAL_EXTENSION_DAYS=30

# Token partagé pour les appels service-to-service auth-service → alert-service
INTERNAL_API_TOKEN=change_me_random_string

# ======================
# STRIPE — subscription-service
# ======================
# Clés API (Stripe Dashboard → Developers → API keys)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Price IDs (Stripe Dashboard → Products → choisir un produit → Prices)
# Chaque produit (PREMIUM / PREMIUM_PLUS) doit avoir un Price récurrent mensuel
# par devise (EUR et XOF).
STRIPE_PRICE_PREMIUM_EUR=price_xxx
STRIPE_PRICE_PREMIUM_XOF=price_xxx
STRIPE_PRICE_PREMIUM_PLUS_EUR=price_xxx
STRIPE_PRICE_PREMIUM_PLUS_XOF=price_xxx

# Coupons : créés directement dans Stripe Dashboard (Products → Coupons)
# Ex : EARLY50 = 50% off, Duration = Forever, ID = EARLY50
# Le code interne (joseph_admin.promo_codes) DOIT correspondre à un coupon
# Stripe portant le même ID (case sensitive).

# Clés publiques (frontend Angular — injectées dans environment.ts/environment.prod.ts).
# Visibles côté client, non sensibles.
STRIPE_PUBLISHABLE_KEY_TEST=pk_test_xxx
STRIPE_PUBLISHABLE_KEY_LIVE=pk_live_xxx

# ======================
# PAYDUNYA — subscription-service (Wave/Orange Money/XOF)
# ======================
# Clés API (PayDunya Dashboard → Mon compte → API)
PAYDUNYA_MASTER_KEY=your_master_key
PAYDUNYA_PRIVATE_KEY=your_private_key
PAYDUNYA_TOKEN=your_token
# Mode : test (sandbox) | live (production)
PAYDUNYA_MODE=test
# URLs de callback — adaptées au domaine de production
PAYDUNYA_CALLBACK_URL=https://api.josephyusuf.com/api/webhooks/paydunya
PAYDUNYA_RETURN_URL=https://josephyusuf.com/subscription/success
PAYDUNYA_CANCEL_URL=https://josephyusuf.com/subscription

# ======================
# PAYTECH — subscription-service (Wave/Orange Money/Free Money/Carte — XOF)
# ======================
# Clés API (PayTech Dashboard → Mon compte → API Keys)
PAYTECH_API_KEY=your_api_key
PAYTECH_API_SECRET=your_api_secret
# Environnement : test (sandbox) | prod (production)
PAYTECH_ENV=test
# URLs — IPN doit pointer vers le webhook backend (signature SHA-256 vérifiée)
PAYTECH_SUCCESS_URL=https://josephyusuf.com/subscription/success
PAYTECH_CANCEL_URL=https://josephyusuf.com/subscription
PAYTECH_IPN_URL=https://api.josephyusuf.com/api/webhooks/paytech

# ======================
# MAIL — auth-service password reset
# ======================
# Stack Docker (docker compose -f docker-compose.yml -f docker-compose.dev.yml up) :
#   le service "mailhog" est résolu sur le réseau joseph-network.
#   UI web : http://localhost:8025
# Dev local sans Docker (auth-service lancé via mvn spring-boot:run) :
#   utiliser MAIL_HOST=localhost et démarrer MailHog manuellement
#   (docker run -p 1025:1025 -p 8025:8025 mailhog/mailhog).
# Prod : SMTP réel (SendGrid, Gmail, Mailgun, etc.)
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=no-reply@josephyusuf.com
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS=false
RESET_URL=http://localhost:4200/reset-password

# ======================
# ADMIN — bootstrap super-admin (auth-service + admin-service)
# ======================
# Liste d'emails (séparés par virgule) promus ADMIN au démarrage d'auth-service
# via SuperAdminBootstrap. L'utilisateur doit déjà exister (créé via
# /api/auth/register) pour que le rôle soit appliqué.
SUPER_ADMIN_EMAILS=admin@josephyusuf.com
ADMIN_FRONTEND_URL=http://localhost:4201

# ======================
# CI/CD — Jenkins (local ou VPS dédié)
# ======================
JENKINS_URL=http://localhost:8090
JENKINS_WEBHOOK_URL=https://your-tunnel.ngrok-free.app/github-webhook/

# ======================
# QUALITY — SonarQube (local ou VPS dédié)
# ======================
SONARQUBE_URL=http://localhost:9000
SONARQUBE_TOKEN=sqa_your_token_here
SONAR_DB_PASSWORD=sonar_secret

# ======================
# REGISTRY (pour build & deploy)
# ======================
REGISTRY_URL=ghcr.io/your-user
REGISTRY_USER=your-user
REGISTRY_PASS=your-token

# ======================
# VPS PRODUCTION (cible de déploiement)
# ======================
VPS_HOST=your-vps-ip-or-domain
VPS_USER=deploy
SSH_KEY_PATH=~/.ssh/id_rsa
