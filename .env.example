# ======================
# APPLICATION (utilisé par docker-compose.yml en dev)
# ======================
DB_USER=joseph
DB_PASSWORD=change_me_in_production
DB_NAME=joseph_db
JWT_SECRET=change_me_64_chars_minimum

# ======================
# MAIL — auth-service password reset
# ======================
# Stack Docker (docker compose -f docker-compose.yml -f docker-compose.dev.yml up) :
#   le service "mailhog" est résolu sur le réseau joseph-network.
#   UI web : http://localhost:8025
# Dev local sans Docker (auth-service lancé via mvn spring-boot:run) :
#   utiliser MAIL_HOST=localhost et démarrer MailHog manuellement
#   (docker run -p 1025:1025 -p 8025:8025 mailhog/mailhog).
# Prod : SMTP réel (SendGrid, Gmail, Mailgun, etc.)
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=no-reply@josephyusuf.com
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS=false
RESET_URL=http://localhost:4200/reset-password

# ======================
# ADMIN — bootstrap super-admin (auth-service + admin-service)
# ======================
# Liste d'emails (séparés par virgule) promus ADMIN au démarrage d'auth-service
# via SuperAdminBootstrap. L'utilisateur doit déjà exister (créé via
# /api/auth/register) pour que le rôle soit appliqué.
SUPER_ADMIN_EMAILS=admin@josephyusuf.com
ADMIN_FRONTEND_URL=http://localhost:4201

# ======================
# CI/CD — Jenkins (local ou VPS dédié)
# ======================
JENKINS_URL=http://localhost:8090
JENKINS_WEBHOOK_URL=https://your-tunnel.ngrok-free.app/github-webhook/

# ======================
# QUALITY — SonarQube (local ou VPS dédié)
# ======================
SONARQUBE_URL=http://localhost:9000
SONARQUBE_TOKEN=sqa_your_token_here
SONAR_DB_PASSWORD=sonar_secret

# ======================
# REGISTRY (pour build & deploy)
# ======================
REGISTRY_URL=ghcr.io/your-user
REGISTRY_USER=your-user
REGISTRY_PASS=your-token

# ======================
# VPS PRODUCTION (cible de déploiement)
# ======================
VPS_HOST=your-vps-ip-or-domain
VPS_USER=deploy
SSH_KEY_PATH=~/.ssh/id_rsa
